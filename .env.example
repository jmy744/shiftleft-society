# ShiftLeft Society — Environment Variables
# Copy this to .env and fill in your values.
# NEVER commit .env to git. Add .env to .gitignore.

# Required: Qwen API key from dashscope.aliyuncs.com
QWEN_API_KEY=your-qwen-api-key-here

# Required for GitHub PR integration
GITHUB_TOKEN=ghp_your_personal_access_token_here
GITHUB_WEBHOOK_SECRET=your-webhook-secret-here

# Set automatically on Alibaba Cloud ECS instances
ALIBABA_CLOUD_REGION=ap-southeast-1
ECS_INSTANCE_ID=i-your-instance-id
